<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profilePic"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:src="@drawable/my_photo"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircularImageViewStyle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nurul Fardina binti Noor Azmi"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ICT602 | CS251 | ID: 2025301517"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/githubLink"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="20dp"
            android:text="Visit GitHub Repository"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1A237E"
            app:cornerRadius="30dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INSTRUCTIONS"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:textSize="12sp"
            android:textColor="#9E9E9E" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/white">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:lineSpacingExtra="6dp"
                android:text="1. Select your billing month from the menu.\n2. Enter electricity units (1-1000 kWh).\n3. Use the slider to define your rebate.\n4. Save your bill details to the local database."
                android:textSize="15sp"
                android:textColor="#424242" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="App Version 1.0.0"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:textSize="12sp"
            android:textColor="#BDBDBD" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 Nurul Fardina. All Rights Reserved."
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textSize="11sp"
            android:textColor="#BDBDBD" />

    </LinearLayout>
</ScrollView>